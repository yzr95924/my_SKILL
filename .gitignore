# 外部工具生成的锁文件 / 配置
package-lock.json
skills-lock.json

# agent 本地配置（用户级，不入库）
# - .claude     Claude Code 项目级（含 settings.local.json 等含 token）
# - .agents     npx skills install 出来的 vendored 副本（软链到 ~/.claude/skills/）
# - .migration-backup  旧 CLAUDE.md → AGENTS.md 拆分时备份目录
# - .mcp.json   Claude Code 项目级 MCP 配置（含 Bearer token，不入库）
# - .qoder      Qoder IDE 项目级（含 settings.local.json 等含 token）—— 与 .claude 同管理逻辑
# `**/` 通配锚定根 + 任意深度子目录 + `settings*.json` 通配 settings 变体——与 workspace-spec §10 `.gitignore` 模板同模式
**/.claude/settings*.json
.agents
.migration-backup
.mcp.json
**/.qoder/settings*.json
# belt-and-suspenders：本地仓层面兜底任何 spec 之外的 IDE 缓存/会话/cache 文件
.claude/
.qoder/

# Python 构建产物
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Python 工具链缓存
.ruff_cache/

# 本地环境 / 密钥
.env
.env.*
!.env.example
*.local

# 编辑器 / 操作系统
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# 通用构建 / 分发目录
dist/
build/
*.pdf

# yzr-skill-creator 评估工作区（Iron Law baseline / 描述优化 / 改进循环产物）
# 与 skill 同级，transient，eval outputs 可能包含大量 agent transcript，跑过后
# 不入库——下次 entry 2 重新走 run_eval.py 即可重建。
*-workspace/
